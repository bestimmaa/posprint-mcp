{
  "name": "@bestimmaa/posprint-mcp",
  "version": "0.2.0",
  "description": "MCP server for printing markdown receipts on POS printers.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/src/server.js",
  "bin": {
    "posprint-mcp": "./dist/src/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bestimmaa/posprint-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/bestimmaa/posprint-mcp/issues"
  },
  "homepage": "https://github.com/bestimmaa/posprint-mcp#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && chmod +x dist/src/cli.js",
    "prepare": "npm run build",
    "start": "node dist/src/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "@bestimmaa/posprint": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
